  <step>
    <name>Origem-Corporativo</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>origem_dw_corporativo</connection>
    <sql>select 
nf.numero_nf,
nf.data_venda,
inf.id_produto,
fp.descricao as forma_pagto,
nf.id_cliente,
pj.razao_social,
pf2.nome as vendedor,
inf.quantidade,
inf.valor_venda_real 
from vendas.item_nota_fiscal inf 
left join vendas.nota_fiscal nf on nf.id = inf.id_nota_fiscal
left join geral.pessoa_fisica pf2 on pf2.id = nf.id_vendedor
left join vendas.forma_pagamento fp on fp.id = nf.id_forma_pagto
left join vendas.produto p on p.id = inf.id_produto
inner join geral.pessoa_juridica pj on pj.id = p.id_fornecedor</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
